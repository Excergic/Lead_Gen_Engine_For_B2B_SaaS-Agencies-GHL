# Copy to .env and fill in values
ENVIRONMENT=development
DEBUG=true

# Operator API key — required on all /api/v1/* routes except /health
API_KEY=change-me-to-a-long-random-string

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase database password (Project Settings → Database → Database password)
# NOT the same as the service role key. Required to run migrations via CLI/script.
SUPABASE_DB_PASSWORD=your-database-password

# Optional
SUPABASE_TIMEOUT_SECONDS=10
# For production: add your Vercel frontend URL
# CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# Perplexity — web search + enrichment
PERPLEXITY_API_KEY=your-perplexity-api-key

# Optional — Apollo.io + Hunter.io for email enrichment (Apollo tried first)
APOLLO_API_KEY=your-apollo-api-key
HUNTER_API_KEY=your-hunter-api-key

DISCOVER_AUDIT_JSONL=data/tool_audit.jsonl
DISCOVER_LEADS_JSONL=data/discovered_leads.jsonl

# Outreach defaults — sign-off name + Calendly link in every generated email
OUTREACH_SENDER_NAME=Dhaivat NJ
OUTREACH_CALENDAR_URL=https://calendly.com/dhaivat-jambudia/new-meeting

# ---------------------------------------------------------------------------
# Email sending (HITL: human approves first, then POST /outreach/{id}/send)
# Set EMAIL_DRY_RUN=false and configure SMTP to enable live sending.
# ---------------------------------------------------------------------------

# Keep true during testing; set false to send live emails
EMAIL_DRY_RUN=true

# --- Gmail (App Password) ---
# 1. Enable 2FA on your Google account
# 2. Go to myaccount.google.com/apppasswords → generate app password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# EMAIL_FROM_ADDRESS=you@gmail.com
# EMAIL_FROM_NAME=Your Name
# EMAIL_REPLY_TO=you@gmail.com

# --- SendGrid ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key
# EMAIL_FROM_ADDRESS=you@yourdomain.com
# EMAIL_FROM_NAME=Your Name

# --- Mailgun ---
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USERNAME=postmaster@mg.yourdomain.com
# SMTP_PASSWORD=your-mailgun-smtp-password
# EMAIL_FROM_ADDRESS=you@yourdomain.com
# EMAIL_FROM_NAME=Your Name

# --- Brevo (formerly Sendinblue) ---
# SMTP_HOST=smtp-relay.brevo.com
